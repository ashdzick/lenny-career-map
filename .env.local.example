# Copy to `.env.local` for local regeneration scripts (never commit real values).

# Required for `npm run build:corpus` — clone transcript markdown repo
GITHUB_TOKEN=

# Required for `npm run generate:paths` — after corpus exists
ANTHROPIC_API_KEY=

# Optional overrides for corpus clone (defaults: LennysNewsletter / lennys-newsletterpodcastdata-all)
# TRANSCRIPT_REPO_OWNER=
# TRANSCRIPT_REPO_NAME=
